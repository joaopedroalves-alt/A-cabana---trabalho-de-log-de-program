#include <bits/stdc++.h>
#include <unistd.h>
using namespace std;

// ENUM DE LOCAIS ================================================================================================================================================================================================================================
enum Local {
    QUARTO,
    CORREDOR,
    COZINHA,
    BANHEIRO,
    SALA
};

int main() {

    system("clear");
    cout << "\x1B[41m A Cabana \x1B[0m\n";
    sleep(2);

    system("clear");
    cout << "Um jogo por: João Pedro Santos Alves\n";
    sleep(2);

    system("clear");
    cout << "Você foi sequestrado e acorda preso em uma cabana abandonada...\n";
    sleep(2);

    int op;
    bool jogando=false;

    // ===== MENU =====================================================================================================================================================================================================================================
    do {
        system("clear");
        cout << "1- Informacões\n2- Começar\n3- Sair\n";
        cin >> op;

        if (op == 1) {
            cout << "Escape room: encontre pistas e itens para sair.\n";
            sleep(1);
        }
        else if (op == 2) {
            jogando = true;
        }
        else if (op == 3) {
            cout << "Não há escapatória...\n";
            jogando = false;
        }

    } while (op != 2 && op != 3);

    // ===== ESTADOS =====================================================================================================================================================================================================================================
    Local local = QUARTO;
    
    bool corrente=true;
    bool temTabua=false;
    bool temChaves=false;
    bool temrastelo=false;
    bool chave1=false;
    bool temmanivela=false;
    int tempecadexadrez=0;
    bool tempistadexadrez=false;
    bool temChaveFinal=false;
    bool chavedocarro=false;
    bool ralo=true;
    bool panelafervendo=true;

    // ===== LOOP PRINCIPAL =====================================================================================================================================================================================================================================
    while (jogando) {

        // ===== QUARTO =====================================================================================================================================================================================================================================
        if (local == QUARTO) {
            system("clear");

            cout << "Você está preso em uma cama desconfortável por uma corrente, ao seu redor existem uma mesa, um armário, uma cama, uma corrente e uma porta. O que fazer?\n";
            cout << "1-Mesa\n2-Armario\n3-Cama\n4-Corrente\n5-Porta\n";

            int escolha;
            cin >> escolha;

            switch (escolha) {

                case 1:
                    cout << "Uma mesa de madeira desgastada e velha possui uma gaveta trancada.\n";
                    if (temChaves) {
                        cout << "Abrir? 1-Sim\n";
                        int u; cin >> u;
                        if (u == 1) {
                            cout <<"Você encontra uma lanterna e as chaves de seu carro.\n";
                            chavedocarro=true;
                        }
                    }
                    break;

                case 2:
                if(corrente){
                    cout << "Não é possível chegar ao armário por causa da corrente, mas ele tem um molho de chaves pendurado que talvez de para pegar com algum objeto.\n";
                    if (temTabua && !temChaves) {
                        cout << "Usar tabua? 1-Sim\n";
                        int e; 
                        cin >> e;
                    

                        if (e == 1) {
                            cout << "Voce pega o molho de chaves.\n";
                            temChaves = true;
                        }
                    }
                }   else {
                        cout << "Você consegue abrir o armário, nele tem diversos itens pessoais de alguém como roupas, papéis, sacos, fotos, mas não parecem ser úteis.\n";
                    }
                    break;

                case 3:
                    cout<<"Parece que alguém não limpa o chão a muito tempo... Uma das tábuas da cama está solta\n";
                    if (!temTabua) {
                        cout << "Peguei a tábua.\n";
                        temTabua = true;
                    } else {
                        cout << "Nada novo.\n";
                    }
                    break;

                case 4:
                    if (temChaves && corrente) {
                        cout << "Usar chave? 1-Sim\n";
                        int t; cin >> t;

                        if (t == 1) {
                            corrente = false;
                            cout << "Finalmente livre dessa corrente.\n";
                        }
                    } else {
                        cout << "A corrente é robusta, acho que eu só preciso achar alguma chave por aqui.\n";
                    }
                    break;

                case 5:
                    if (corrente) {
                        cout << "Eu não alcanço a porta por causa dessa corrente maldita!\n";
                    } else {
                        cout << "Sair? 1-Sim\n";
                        int s; cin >> s;

                        if (s == 1) {
                            local = CORREDOR;
                        }
                    }
                    break;

                default:
                    cout << "Opcão inválida.\n";
            }

            sleep(6);
        }

        // ===== CORREDOR =====================================================================================================================================================================================================================================
        else if (local == CORREDOR) {
            system("clear");

            cout << "Esse lugar é pequeno, na esquerda tem uma porta, se eu seguir reto tem uma cozinha e do lado dela uma sala.\n Para onde eu vou?\n";
            cout << "1-Cozinha 2-Porta 3-Sala\n";

            int p;
            cin >> p;

            if (p == 1) local = COZINHA;
            else if (p == 2) local = BANHEIRO;
            else if (p == 3) local = SALA;
            sleep(7);
        }

        // ===== COZINHA ================================================================================================================================================================================================================================
        else if (local == COZINHA) {
            system("clear");

            cout << "Para a cozinha...\nO chão é quadriculado, os armários são velhos e encardidos, as portas são meio soltas, no fogão tem uma panela que está no fogo. A cuba está cheia de louça suja, o local fede.\n";
            cout << "1-Pia\n2-Armário\n3-Fogão\n4-Voltar\n";

            int c;
            cin >> c;

            if(c==1) {
                if(!temmanivela){
                    cout << "Louça suja acumulada. Dentro de um dos potes tem uma manivela.\n";
                temmanivela=true;
                }
                else{
                    cout << "Só louça suja aqui.\n";
                }
            }
            else if(c==2) {
                cout << "Os armários são velhos, mas um deles tem uma tranca.\n";
                if(chave1){
                    cout<<"A chave encaixa aqui...\nDentro tem uma peça de xadrez,uma rainha, e um papel, nele tem grupos de letras e números:\n e4\n c4\n h5\n f7\n e no fim: o remédio de agora!";
                    tempistadexadrez=true;
                    tempecadexadrez++;
                    chave1 = false;
                }
                else{
                    cout<<"Eu já fiz isso...\n";
                }
            }
            else if(c==3){
                cout<<"No fogão tem uma panela fervendo.\nApagar o fogo? 1-Sim.\n";
                int y;cin>>y;
                    if(y==1 && panelafervendo){
                        cout<<"O fogo apaga e depois de um tempo parece esfriar esse líquido avermelhado e parece ter algo no fundo...\n O líquido é estranho, melhor não pensar muito sobre, dentro uma outra peça de xadrez o bispo.";
                        tempecadexadrez++;
                        panelafervendo=false;
                    }
                    else{
                        cout<<"eu já fiz isso\n";
                    }
            }
            else if(c==4) {
                local = CORREDOR;
            }

            sleep(7);
        }

        // ===== BANHEIRO =====================================================================================================================================================================================================================================
        else if (local == BANHEIRO) {
            system("clear");

            cout << "Para a porta então... O ambiente é sujo, tem água no chão, uma toalha jogada em cima da pia, acima da pia um armário aberto com alguns remédios, e na banheira";
            if(ralo){
                cout<<"uma torneira ligada que faz transbordar e cair água esporadicamente.\n";   
            }
            else if(!ralo){
                cout<<"a torneira ainda ligada cai água, mas a banheira está vazia.\n";
            }
            cout << "1-Banheira 2-Remédios 3-Voltar\n";

            int b;
            cin >> b;

            if (b == 1) {
                cout << "Água suja na banheira, ela cai de vez em quando. Parece ter algo dentro, mas eu não quero arriscar colocar a mão dentro, talvez se eu usar algum item.\n";
                    if(temrastelo && ralo){
                        ralo=false;
                        cout<<"Acho que com isso dá para pegar algo...\nO som de uma rolha sendo destampado é feito, o nível da água passa a diminuir, preso na corrente do ralo uma chave pequena e dourada.";
                        chave1=true;
                    }
                    else if(!ralo){
                        cout<<"Já peguei o que tiha aqui\n";
                    }
                    else{
                    cout<<"Preciso de algo para alcançar.\n";
                    }
                    
            }
            else if (b == 2) {
                cout << "Vários remédios espalhados, alguns deles parecem ter sido usados recentemente, um papel tem horários mostra os seguintes horários:\n 15:35 - 1-aripiprazol\n 16:40 - 2-Respiridona\n 17:15 - 3-Haloperidol";
            }
            else if (b == 3) {
                local = CORREDOR;
            }

            sleep(8);
        }

        // ===== SALA =====================================================================================================================================================================================================================================
        else if (local == SALA) {
            system("clear");

            cout << "Para a sala então\n Ela tem iluminação oriunda de uma lareira, em cima preso uma cabeça de veado com olhos vidrados, na parede ao lado um relógio de ponteiro travado e uma porta que parece dar para a saída desse lugar, porém ela está trancada e ao lado uma pequena mesa.\n";
            cout << "1-Relogio\n2-Lareira\n3-Cabeça empalhada\n4-Porta\n5-Voltar\n";

            int s;
            cin >> s;

            if(s==1){
                cout << "Relógio parado com ponteiros travados no horário das 17:14\n";
            }
            else if(s==2){
                cout <<"A lareira está acesa com a chama alta, o rastelo de lenha está cravado em uma tábua, ele está incandescente.\nPegar? 1-Sim";
                int r; cin>>r;
                if(r==1 && !temrastelo){
                    temrastelo=true;
                }    
            }
            else if(s==3){
                cout<<"Essa cabeça parece me seguir com o olhar, é estranho. A boca dele tem um mecanismo que parece abrir a boca, mas falta uma peça.\n";
                if(temmanivela){
                    cout<<"Dá para colocar a manivela no mecanismo...\nAs peças estão meio travadas, mas funcionam e a boca começa a abrir.\nDe dentro dela cai uma peça de xadrez do peão\n";
                    tempecadexadrez++;
                    temmanivela=false;
                }
            }
            else if(s==4){
                cout<<"A porta de saída, ela está trancada...eu não tenho forças para forçar a porta. E essa mesa também está trancada e ela tem um tabuleiro de xadrez, o que eu faço com isso?\nO cadeado da mesa usa 4 letras e um número.";

                if(tempecadexadrez==3 && tempistadexadrez){
                    cout<<"Se eu colocar as peças faltando na ordem das casas eu tenho 'pbqq'\n";
                    cout << "\nDigite a senha: ";

                    string senha;
                    cin >> senha;

                    if(senha == "pbqq3"){
                        cout<<"O cadeado faz um click, a gaveta se abre e dentro uma chave de ferro puro pesada e adornada\n";
                        temChaveFinal = true;

                        jogando = false;
                        system("clear");

                        cout<<"A chave encaixa... a porta se abre lentamente.\n";
                        sleep(2);

                        cout<<"La fora esta completamente escuro.\n";
                        sleep(2);

                        if(chavedocarro){
                            cout<<"\nVoce encontra seu carro.\n";
                            sleep(1);
                            cout<<"Liga o motor...\n";
                            sleep(1);
                            cout<<"\x1B[42mVoce escapou.\x1B[0m\n";
                        }
                        else{
                            cout<<"\nVoce encontra seu carro...\n";
                            sleep(2);
                            cout<<"Mas... sem a chave.\n";
                            sleep(2);
                            cout<<"Luzes surgem na escuridao.\n";
                            sleep(2);
                            cout<<"Algo se aproxima.\n";
                            sleep(2);
                            cout<<"\x1B[41mDessa vez nao ha escapatoria.\x1B[0m\n";
                        }

                        sleep(4);
                        system("clear");
                        cout<<"\n\x1B[41m===== FIM =====\x1B[0m\n";
                        
                    }
                }
            }
         
            else if (s == 5) {
                local = CORREDOR;
            }
            sleep(6);
        }
    }

    return 0;
}
